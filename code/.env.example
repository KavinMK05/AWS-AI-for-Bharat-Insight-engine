# Insight Engine — Environment Variables
# Copy this to .env and fill in real values.
# NEVER commit .env — it is gitignored.

# AWS
AWS_REGION=ap-south-1
ENVIRONMENT=dev

# DynamoDB
TABLE_PREFIX=dev-

# SQS Queue URLs (set after terraform apply)
INGESTION_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/ACCOUNT_ID/insight-engine-dev-ingestion-queue
GENERATION_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/ACCOUNT_ID/insight-engine-dev-generation-queue
PUBLISH_QUEUE_URL=https://sqs.ap-south-1.amazonaws.com/ACCOUNT_ID/insight-engine-dev-publish-queue

# S3 Buckets (set after terraform apply)
PERSONA_FILES_BUCKET=insight-engine-dev-persona-files
LAMBDA_DEPLOYMENTS_BUCKET=insight-engine-dev-lambda-deployments

# SNS (set after terraform apply)
ADMIN_ALERTS_TOPIC_ARN=arn:aws:sns:ap-south-1:ACCOUNT_ID:insight-engine-dev-admin-alerts

# Scoring
RELEVANCE_THRESHOLD=60
