# Insight Engine Dashboard — Environment Variables
# Copy this file to .env.local and fill in real values.

# API Gateway base URL (from Terraform output: api_gateway_url)
NEXT_PUBLIC_API_BASE_URL=https://your-api-id.execute-api.ap-south-1.amazonaws.com

# NextAuth.js configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# AWS Cognito (from Terraform output: cognito_user_pool_id, cognito_client_id)
COGNITO_ISSUER=https://cognito-idp.ap-south-1.amazonaws.com/your-user-pool-id
COGNITO_CLIENT_ID=your-cognito-client-id
COGNITO_CLIENT_SECRET=your-cognito-client-secret
