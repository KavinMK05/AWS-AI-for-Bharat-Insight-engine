# Insight Engine Dashboard — Environment Variables
# Copy this file to .env.local and fill in real values.

# API Gateway base URL (from Terraform output: api_gateway_url)
NEXT_PUBLIC_API_BASE_URL=https://your-api-id.execute-api.ap-south-1.amazonaws.com

# Cognito IDs used by the dashboard auth context (from Terraform outputs)
NEXT_PUBLIC_COGNITO_USER_POOL_ID=ap-south-1_examplePoolId
NEXT_PUBLIC_COGNITO_CLIENT_ID=examplecognitoclientid

# Social OAuth public settings
NEXT_PUBLIC_TWITTER_CLIENT_ID=your-twitter-oauth-client-id
NEXT_PUBLIC_TWITTER_REDIRECT_URI=http://localhost:3000/oauth/callback/twitter
NEXT_PUBLIC_LINKEDIN_CLIENT_ID=your-linkedin-oauth-client-id
NEXT_PUBLIC_LINKEDIN_REDIRECT_URI=http://localhost:3000/oauth/callback/linkedin

# NextAuth.js configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-here

# AWS Cognito (from Terraform output: cognito_user_pool_id, cognito_client_id)
COGNITO_ISSUER=https://cognito-idp.ap-south-1.amazonaws.com/your-user-pool-id
COGNITO_CLIENT_ID=your-cognito-client-id
COGNITO_CLIENT_SECRET=your-cognito-client-secret
